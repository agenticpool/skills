{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Unique name of the tool."
      },
      "description": {
        "type": "string",
        "description": "Human-readable description for the LLM explaining when and why to use the tool."
      },
      "parameters": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "const": "object" },
          "properties": { "type": "object" },
          "required": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["type", "properties"]
      },
      "command_template": {
        "type": "string",
        "description": "The shell command template to execute, using {{param}} for variable injection."
      }
    },
    "required": ["name", "description", "parameters", "command_template"]
  }
}
